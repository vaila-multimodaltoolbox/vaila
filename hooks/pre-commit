#!/bin/bash

# Maximum allowed size in bytes (20 MiB = 20 * 1024 * 1024). Staged files this size or larger fail.
max_size=$((20 * 1024 * 1024))

# Only check Added/Copied/Modified/Renamed — never Deleted (D): removed paths can still exist
# on disk and would falsely fail the size check. Use ACMR, not --diff-filter=d (Git differs by version).
while IFS= read -r file; do
  [ -z "$file" ] && continue
  if [ -f "$file" ]; then
    file_size=$(wc -c <"$file")
    if [ "$file_size" -ge "$max_size" ]; then
      echo "Error: The file '$file' is $(($file_size / 1024 / 1024)) MiB, which exceeds the 20 MiB limit."
      exit 1
    fi
  fi
done < <(git diff --cached --name-only --diff-filter=ACMR)