# Project specific
datasets/
bin/ffmpeg/

# vaila/models: track small reference files (e.g. *.csv, *.json <20MB). Ignore weight-like
# binaries (Git cannot ignore by size; pre-commit rejects staged files ≥20MB — hooks/pre-commit).
vaila/models/**/*.pt
vaila/models/**/*.ckpt
vaila/models/**/*.onnx
vaila/models/**/*.engine
vaila/models/**/*.task
vaila/models/**/*.pth
vaila/models/**/*.bin
# Small sklearn/joblib *.pkl (e.g. walkway_ml_prediction defaults) stay tracked if <20 MiB; hook blocks larger.
vaila/models/**/*.safetensors
# Hugging Face hub cache under models (e.g. facebook/sam3 downloads)
vaila/models/**/.cache/

# Local Hugging Face datasets/models (offline training assets)
vaila/models/hf_datasets/

# Ultralytics training runs (local artifacts)
runs/
vaila/models/runs/

# Stray weight files at repository root (use vaila/models/ instead)
/*.pt
/*.ckpt
/*.onnx
/*.pkl
/*.safetensors

# Legacy SAM3 download folder at repo root (use vaila/models/sam3/; see vaila_sam.py)
sam3_weights/

# Keep the model directories in GitHub, but track only *.txt instructions inside them.
# (Weights and other large artifacts must remain local; see instruction_to_download_models.txt)
vaila/models/sam3/*
!vaila/models/sam3/*.txt

vaila/models/sam-3d-dinov3/*
!vaila/models/sam-3d-dinov3/*.txt

vaila/models/trackers/*
!vaila/models/trackers/*.txt

# SAM GPU smoke sample (often >20 MiB; see tests/SAM/README.md)
tests/SAM/*.mp4

# General temporary files
.DS_Store
.AppleDouble
.LSOverride
*.bak
*.backup
*.tmp
*.temp

# Ignore .app directories (macOS application bundles)
*.app

# Video files
*.MOV
*.mov
*.AVI
*.avi
# Ignore all mp4 files in tests/sport_fields/
tests/sport_fields/*.mp4

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# C extensions
*.so

